# Copy this file to /etc/daikin-web.env and edit it for your home.

DAIKIN_HOST=127.0.0.1
DAIKIN_WEB_PORT=5050
DAIKIN_ADAPTER=hci0
PYMADOKA_BIN=/opt/pymadoka-venv/bin/pymadoka

# Replace the sample MAC addresses with the BLE MACs of your own controllers.
# IDs should be lowercase, stable, and not contain spaces.
DAIKIN_DEVICES='[{"id":"living_room","name":"Living room","mac":"AA:BB:CC:DD:EE:01"},{"id":"bedroom","name":"Bedroom","mac":"AA:BB:CC:DD:EE:02"}]'

# Tuning. Defaults are usually fine.
DAIKIN_STATUS_TTL=60
DAIKIN_FAILURE_COOLDOWN=120
DAIKIN_PYMADOKA_TIMEOUT=40
DAIKIN_PYMADOKA_RETRIES=0
DAIKIN_POST_CALL_SETTLE=1.0
DAIKIN_MAX_POST_BODY=4096
